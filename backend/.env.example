# Copy to `.env` in this folder (docker compose reads it automatically).
# SQL Server (container + API connection)
SQL__DATABASE=sohDbv1
SQL__USER=sa
# Must meet SQL Server complexity (length, upper/lower/digit/symbol)
SQL__PASSWORD=SohLocal_Dev_v1!
SQL__PID=Developer

# RabbitMQ (matches docker-compose rabbitmq service)
RABBITMQ__HOST=rabbitmq
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
