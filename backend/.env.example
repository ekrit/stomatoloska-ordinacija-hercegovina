# Copy to .env next to docker-compose (and to backend/ for local `dotnet run`)
# and adjust. Never commit real secrets. The API and Subscriber call
# DotNetEnv at startup, so any value here is also picked up for plain
# `dotnet run` outside Docker.

# --- SQL Server --------------------------------------------------------------
SQL__DATABASE=SOH_Dev
SQL__USER=sa
SQL__PASSWORD=Your_Strong_Password_Here
SQL__PID=Developer

# --- RabbitMQ ----------------------------------------------------------------
RABBITMQ__HOST=rabbitmq
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest

# Optional: comma-separated emails for appointment reminder worker (subscriber)
# APPOINTMENT_REMINDER_RECIPIENTS=ops@example.com

# --- JWT signing key ---------------------------------------------------------
# 32+ random chars. ASP.NET maps "__" -> ":" so this overrides
# JwtSettings:SecretKey in appsettings.json.
JwtSettings__SecretKey=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32_CHARS_MIN
JwtSettings__Issuer=SOH.WebAPI
JwtSettings__Audience=SOH.App
JwtSettings__ExpirationMinutes=60

# --- SMTP (appointment reminder emails) --------------------------------------
# Used by SOH.Subscriber/EmailSenderService. With Gmail use an App Password,
# not the account password. Leave blank to disable email sending entirely
# (the worker will log a warning and keep consuming reminders).
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__ENABLESSL=true
SMTP__USERNAME=
SMTP__PASSWORD=
SMTP__FROM=

# --- PayPal sandbox (in-app appointment payment) -----------------------------
# Create REST API app credentials at https://developer.paypal.com (Sandbox).
# Leave CLIENT_ID/SECRET blank to disable payments (endpoints return a clear
# "PayPal is not configured" error). BASE_URL stays on sandbox by default.
PAYPAL__BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL__CLIENT_ID=
PAYPAL__CLIENT_SECRET=
PAYPAL__WEBHOOK_ID=
PAYPAL__RETURN_URL=https://example.com/paypal/return
PAYPAL__CANCEL_URL=https://example.com/paypal/cancel

